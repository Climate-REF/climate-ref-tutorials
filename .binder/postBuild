#!/usr/bin/env bash
# Binder/repo2docker postBuild hook.
#
# repo2docker installs .binder/requirements.txt first, then runs this script.
# Here we install the helper package, generate the REF API client, and pre-fetch the sample data.
set -euo pipefail

# Install the ref_tutorials helper package from this repo.
python -m pip install --no-deps .

# Generate and install the REF API client from the live schema.
bash scripts/generate_client.sh

# Pre-fetch the CMIP6 sample data so notebook 04 runs without a download wait.
python -c "from ref_tutorials import fetch_sample_data; fetch_sample_data()"

# Pre-build the matplotlib font cache to save memory
python -c "import matplotlib.pyplot as plt; plt.figure(); plt.text(0, 0, 'warm fonts'); plt.close('all')"
